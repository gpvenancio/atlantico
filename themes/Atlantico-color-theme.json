{
  "name": "Atlantico",
  "semanticHighlighting": true,

  "colors": {
    "editor.background": "#232530",
    "editor.foreground": "#CDD6E3",

    "editor.lineHighlightBackground": "#272A34",
    "editor.selectionBackground": "#6C708628",

    "editorCursor.foreground": "#C8C8C8",

    "editorGutter.background": "#232530",

    "editorIndentGuide.background1": "#2D313D",
    "editorIndentGuide.activeBackground1": "#434A5B",

    "sideBar.background": "#21232D",
    "sideBar.border": "#00000000",

    "activityBar.background": "#1D1F28",
    "activityBar.border": "#00000000",

    "activityBarBadge.background": "#3A4052",
    "activityBarBadge.foreground": "#CDD6E3",

    "titleBar.activeBackground": "#1D1F28",
    "titleBar.border": "#00000000",

    "editorGroupHeader.tabsBackground": "#1F212B",

    "tab.activeBackground": "#252733",
    "tab.inactiveBackground": "#1F212B",

    "statusBar.background": "#232530",
    "statusBar.foreground": "#CDD6E3",

    "statusBar.debuggingBackground": "#2A2D37",

    "statusBar.noFolderBackground": "#232530",
    "statusBar.noFolderForeground": "#CDD6E3",

    "statusBarItem.remoteBackground": "#232530",
    "statusBarItem.remoteForeground": "#CDD6E3",

    "statusBarItem.prominentBackground": "#2A2D37",
    "statusBarItem.prominentForeground": "#CDD6E3",

    "statusBar.debuggingForeground": "#CDD6E3",
    "statusBar.debuggingBorder": "#00000000",

    "scrollbarSlider.background": "#3A3F4B55",
    "scrollbarSlider.hoverBackground": "#4A506055",
    "scrollbarSlider.activeBackground": "#5A607055",

    "terminal.background": "#232530",
    "terminal.foreground": "#CDD6E3",

    "terminalCursor.background": "#CDD6E3",
    "terminalCursor.foreground": "#CDD6E3",

    "terminal.selectionBackground": "#6C708628",

    "terminal.ansiBlack": "#2A2D37",
    "terminal.ansiRed": "#BE7878",
    "terminal.ansiGreen": "#769986",
    "terminal.ansiYellow": "#A98D63",
    "terminal.ansiBlue": "#729BB3",
    "terminal.ansiMagenta": "#9A84C7",
    "terminal.ansiCyan": "#7AA2B8",
    "terminal.ansiWhite": "#CDD6E3",

    "terminal.ansiBrightBlack": "#5B6273",
    "terminal.ansiBrightRed": "#C77D7D",
    "terminal.ansiBrightGreen": "#86A995",
    "terminal.ansiBrightYellow": "#B89B6A",
    "terminal.ansiBrightBlue": "#84A9BF",
    "terminal.ansiBrightMagenta": "#A695D6",
    "terminal.ansiBrightCyan": "#8EB8C7",
    "terminal.ansiBrightWhite": "#E6EDF7"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5B6273"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#CDD6E3"
      }
    },
    {
      "name": "Colors",
      "scope": ["constant.other.color"],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#8AA7B1"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#729BB3"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": ["meta.block variable.other"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": ["support.other.variable", "string.other.link"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "variable.parameter",
        "keyword.other.unit",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#8487D6"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#C4A46B"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#B8A58A"
      }
    },
    {
      "name": "Entity Types",
      "scope": ["support.type"],
      "settings": {
        "foreground": "#A7B4C2"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#A7B4C2"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Language methods",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": ["entity.name.method.js"],
      "settings": {
        "foreground": "#729BB3"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#729BB3"
      }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B8A58A"
      }
    },
    {
      "name": "CSS Classes",
      "scope": ["entity.other.attribute-name.class"],
      "settings": {
        "foreground": "#B8A58A"
      }
    },
    {
      "name": "CSS ID's",
      "scope": ["source.sass keyword.control"],
      "settings": {
        "foreground": "#729BB3"
      }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#86A98D"
      }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#BE7878"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#8AA7B1"
      }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#8AA7B1"
      }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
